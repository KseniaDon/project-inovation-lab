{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "me without token returns 401",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401
    },
    {
      "name": "check_nick unknown returns 403",
      "method": "POST",
      "path": "/?action=check_nick",
      "body": {"nickname": "unknown_xyz_123"},
      "expectedStatus": 403
    },
    {
      "name": "check_nick super_admin returns 200",
      "method": "POST",
      "path": "/?action=check_nick",
      "body": {"nickname": "soul__shu"},
      "expectedStatus": 200,
      "expectedBody": {"role": "super_admin"},
      "bodyMatcher": "partial"
    }
  ]
