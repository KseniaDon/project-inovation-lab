{
  "tests": [
    {
      "name": "Получить список заявок",
      "method": "GET",
      "path": "/?action=list",
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "Проверить доступ — ссылки нет в списке, отказ",
      "method": "GET",
      "path": "/?action=check_access&vk_link=https://vk.com/__nobody__test__",
      "expectedStatus": 403,
      "bodyMatcher": "partial"
    },
    {
      "name": "Отправить ответы с неверным кодом активации",
      "method": "POST",
      "path": "/?action=submit",
      "body": {
        "nickname": "Test_User",
        "vk_link": "https://vk.com/test",
        "department": "ОИК",
        "activation_code": "000",
        "answers": {"q1": "Тестовый ответ"}
      },
      "expectedStatus": 403,
      "bodyMatcher": "partial"
    },
    {
      "name": "Сброс сессии — добавить ник в стоп-лист",
      "method": "POST",
      "path": "/?action=reset_session&nick=test_user_reset",
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "Проверка сброса — ник в стоп-листе, вернуть reset=true и снять флаг",
      "method": "GET",
      "path": "/?action=check_reset&nick=test_user_reset",
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "Загрузить макс. баллы",
      "method": "GET",
      "path": "/?action=scores",
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "Сохранить макс. баллы",
      "method": "POST",
      "path": "/?action=save_scores",
      "body": {"scores": {"3.10": 5, "3.11": 5}},
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "Получить код активации",
      "method": "GET",
      "path": "/?action=get_activation_code",
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "Принудительно обновить код активации",
      "method": "POST",
      "path": "/?action=rotate_activation_code",
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "Получить кастомные вопросы",
      "method": "GET",
      "path": "/?action=get_questions",
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "Сохранить кастомные вопросы",
      "method": "POST",
      "path": "/?action=save_questions",
      "body": {"questions": {"3.4": {"text": "Тестовый вопрос", "options": ["A", "B"], "correct": "A"}}},
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    }
  ]
}